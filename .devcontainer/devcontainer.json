{
  "name": "OtelPoc .NET 10",
  "image": "mcr.microsoft.com/devcontainers/dotnet:2-10.0",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode", 
  "updateRemoteUserUID": true,
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime"
      ],
      "settings": {
        "dotnet.defaultSolution": "OtelPoc.sln"
      }
    }
  },
  "postCreateCommand": "dotnet restore",
  "remoteEnv": {
    "OTEL_SERVICE_NAME": "otel-poc-api-dev",
    "SERVICE_INSTANCE_ID": "devcontainer",
    "SEND_TARGET_URL": "http://localhost:5001",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://otel-collector:4317",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc"
  },
  "forwardPorts": [5001, 5002, 3000]
}
